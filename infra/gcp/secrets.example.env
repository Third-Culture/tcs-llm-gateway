# LLM Gateway — required and optional secrets.
#
# Each name in this file is a Secret Manager secret in the target GCP
# project. Service definitions reference these by name; the secret
# values themselves are never committed.
#
# Mark required ones with [REQUIRED]. Everything else is opt-in based on
# the providers and integrations enabled.

# --- Core auth & key hashing -------------------------------------------------
# [REQUIRED] 32+ chars; used by Better Auth for session/token signing.
AUTH_SECRET=

# [REQUIRED] HMAC key used to fingerprint gateway API keys at rest.
# Rotating this immediately invalidates every issued gateway API key.
GATEWAY_API_KEY_HASH_SECRET=

# --- Backing services -------------------------------------------------------
# [REQUIRED] Cloud SQL Postgres connection string. Use a private IP and
# the Cloud SQL Auth Proxy sidecar in production.
DATABASE_URL=

# [REQUIRED] Memorystore Redis connection URL.
REDIS_URL=

# --- LLM provider API keys (optional, set what you use) ---------------------
LLM_OPENAI_API_KEY=
LLM_ANTHROPIC_API_KEY=
LLM_GOOGLE_AI_STUDIO_API_KEY=
LLM_GOOGLE_VERTEX_API_KEY=
LLM_GROQ_API_KEY=
LLM_X_AI_API_KEY=
LLM_DEEPSEEK_API_KEY=
LLM_MISTRAL_API_KEY=
LLM_PERPLEXITY_API_KEY=
LLM_TOGETHER_AI_API_KEY=
LLM_ALIBABA_API_KEY=
LLM_NEBIUS_API_KEY=
LLM_CEREBRAS_API_KEY=
LLM_MOONSHOT_API_KEY=
LLM_NOVITA_AI_API_KEY=
LLM_AWS_BEDROCK_API_KEY=
LLM_AZURE_API_KEY=
LLM_INFERENCE_NET_API_KEY=
LLM_NANO_GPT_API_KEY=

# --- OAuth (optional) -------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe / billing (optional) -------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=

# --- Observability (optional) ----------------------------------------------
OTEL_SERVICE_NAME=
OTEL_EXPORTER_OTLP_ENDPOINT=
POSTHOG_KEY=
POSTHOG_HOST=

# --- Notifications (optional) ----------------------------------------------
DISCORD_WEBHOOK_URL=
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
